pipeline {
    agent {
        docker {
            image 'node:18-alpine'
            reuseNode true
        }
    }
    stages {
        stage('Get Version') {
            steps {
                sh '''
                    node --version
                    npm --version
                    npm start
                    npm ci
                    npm run build
                    ls -al
                '''
            }
        }
        stage('Test') {
            steps {
                sh '''
                    test -f build/index.html
                '''
            }
        }
    }
}