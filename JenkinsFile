pipeline {
    agent {
        docker {
            image 'node:latest'
            reuseNode true
        }
    }

    stages {
        stage('Get Version') {
            steps {
                sh '''
                    whoami
                    ls -al
                    node --version
                    npm --version
                    npm ci
                    npm run build
                    ls -al
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    test -f build/index.html
                    npm test
                '''
            }
        }
    }

    post { 
        always {
            junit 'test-results/junit.xml'
        }
    }
}